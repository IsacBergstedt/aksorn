# Copy to .env.local and fill in from your Supabase project settings.
# Without these the app still runs, in guest-only mode (localStorage progress).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Script-only secrets for scripts/generate-audio.ts (TTS generation + upload).
# Never NEXT_PUBLIC_-prefixed, never committed — the browser must not see these.
SUPABASE_SERVICE_ROLE_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
