  "exercises": [
    {
      "type": "concept",
      "title": "Some vowels come first",
      "thaiExample": "เก แก",
      "body": [
        "เ and แ are written to the LEFT of their consonant but pronounced AFTER it: เก is k + e — \"ke\", never \"ek\".",
        "Train your eyes to swing back: see เ, hold it, read the consonant, then say the vowel.",
        "The short versions add ะ at the end: เกะ, แกะ."
      ]
